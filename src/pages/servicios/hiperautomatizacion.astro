---
import Layout from '../../layouts/Layout.astro';
import HiperApp from '../../components/HiperApp.jsx';
import { getImage } from 'astro:assets';
import heroSrc from '../../assets/images/texture-arch-lattice.jpg';

const heroOptimized = await getImage({ src: heroSrc, format: 'webp', quality: 82, width: 2400 });
const heroImage = {
  src: heroOptimized.src,
  width: heroOptimized.attributes.width,
  height: heroOptimized.attributes.height,
};
---
<Layout title="Hiperautomatización de Procesos — Brainmap">
  <HiperApp heroImage={heroImage} client:load />
</Layout>
